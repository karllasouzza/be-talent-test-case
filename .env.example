# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# MySQL container (mirrors DB_* for use by docker/mysql.yaml)
MYSQL_ROOT_PASSWORD=
MYSQL_ROOT_HOST=%
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
